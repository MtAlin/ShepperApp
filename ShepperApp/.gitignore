# Root monorepo .gitignore

# Dependencies
node_modules
**/node_modules

# Build outputs
dist
dist-ssr
**/dist

# Environment variables — NEVER commit real .env files
.env
.env.local
.env.production
**/.env
**/.env.local
**/.env.production
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Lock files (optional — keep if you want reproducible installs)
# bun.lock
# package-lock.json
