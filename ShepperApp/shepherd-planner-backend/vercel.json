{
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    { "src": "shepherd-planner-ui/package.json", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.js" },
    { "src": "/(.*)", "dest": "shepherd-planner-ui/$1" }
  ]
}
